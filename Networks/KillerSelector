--[[
  killer selection algo
  rules: the players who have been killer the fewest times
  in the server are the candidates, then one is chosen at random

  Ties are broken randomly
  i.e:
    Dude1 = 1, Dude2 = 2, Dude3 = 0, Dude4 = 0
     candidates = { Dude3, Dude4 }
     chosen = one of them at random
]]

local KillerSelector = {}

function KillerSelector.SelectKiller(
	players: { Player },
	killerHistory: { [number]: number }
	): Player
	
	assert(#players > 0, "KillerSelector: no players")
	
	-- Every player has a default count of 0
	local counts: { [number]: number } = {}
	for _, player in ipairs(players) do
		counts[player.UserId] = killerHistory[player.UserId] or 0
	end
	
	-- Find the lowest count
	local minCount = math.huge
	for _, count in pairs(counts) do
		if count < minCount then minCount = count end
	end
	
	
	-- Get all the players tied at the minimum
	local candidates: { Player } = {}
	for _, player in ipairs(players) do
		if counts[player.UserId] == minCount then
			table.insert(candidates, player)
		end
	end
	
	-- Random pick among candidates
	return candidates[math.random(1, #candidates)]
end
--------------------------------------------------------------------------------------------


-- Call this once after each round to update the killerhistory table
function KillerSelector.RecordKillerRound(
	killerHistory: { [number]: number},
	killer: Player
)
	killerHistory[killer.UserId] = (killerHistory[killer.UserId] or 0) + 1
end
	
	
-- Debug/ui
function KillerSelector.DebugStats(
	players: { Player },
	killerHistory: { [number]: number }
): string
	
	local lines = {}
	for _, player in ipairs(players) do
		table.insert(lines, string.format(
			"%s: %d rounds as killer",  -- %s = string %d is decimal integer
			player.Name,
			killerHistory[player.UserId] or 0
			))
	end
	return table.concat(lines, "\n") -- n joins with new lines 
end


return KillerSelector
